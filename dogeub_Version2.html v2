<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doge Unblocker</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: 'Comic Sans MS', cursive, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .container {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
        }
        
        h1 {
            color: #FFD700;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
            margin-bottom: 10px;
            text-align: center;
        }
        
        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 0.9em;
        }
        
        .input-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: bold;
            font-size: 1.1em;
        }
        
        input[type="text"] {
            width: 100%;
            padding: 12px;
            border: 2px solid #667eea;
            border-radius: 10px;
            font-size: 1em;
            font-family: 'Comic Sans MS', cursive;
            transition: all 0.3s;
        }
        
        input[type="text"]:focus {
            outline: none;
            border-color: #764ba2;
            box-shadow: 0 0 10px rgba(118, 75, 162, 0.3);
        }
        
        button {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1.2em;
            font-weight: bold;
            font-family: 'Comic Sans MS', cursive;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }
        
        button:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        button:active {
            transform: scale(0.98);
        }
        
        #result {
            margin-top: 30px;
            padding: 20px;
            background: #f0f0f0;
            border-radius: 10px;
            display: none;
            text-align: center;
        }
        
        #result.show {
            display: block;
            animation: slideIn 0.3s ease;
        }
        
        #result h2 {
            color: #667eea;
            margin-bottom: 10px;
        }
        
        #result p {
            color: #333;
            word-break: break-all;
        }
        
        .copy-btn {
            background: #FFD700;
            color: #333;
            padding: 10px 20px;
            width: auto;
            margin-top: 15px;
            font-weight: bold;
        }
        
        .copy-btn:hover {
            background: #FFC700;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .doge-emoji {
            font-size: 2em;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1><span class="doge-emoji">🐕</span> Doge Unblocker <span class="doge-emoji">🐕</span></h1>
        <p class="subtitle">Much proxy. Very unblock. Wow.</p>
        
        <div class="input-group">
            <label for="urlInput">Enter Website URL:</label>
            <input type="text" id="urlInput" placeholder="https://example.com" required>
        </div>
        
        <button onclick="unblockURL()">🚀 Such Unblock! Wow!</button>
        
        <div id="result">
            <h2>✨ Unblocker Link ✨</h2>
            <p id="resultURL"></p>
            <button class="copy-btn" onclick="copyToClipboard()">📋 Copy Link</button>
        </div>
    </div>
    
    <script>
        function unblockURL() {
            const urlInput = document.getElementById('urlInput').value.trim();
            const resultDiv = document.getElementById('result');
            const resultURL = document.getElementById('resultURL');
            
            if (!urlInput) {
                alert('Much error! Please enter URL. Wow.');
                return;
            }
            
            let url = urlInput;
            if (!url.startsWith('http://') && !url.startsWith('https://')) {
                url = 'https://' + url;
            }
            
            try {
                new URL(url);
            } catch (e) {
                alert('Such invalid URL! Wow.');
                return;
            }
            
            // Base64 encoding method
            const encodedURL = btoa(url);
            const unblockedLink = window.location.origin + '/?url=' + encodedURL;
            
            resultURL.textContent = unblockedLink;
            resultDiv.classList.add('show');
        }
        
        function copyToClipboard() {
            const resultURL = document.getElementById('resultURL').textContent;
            navigator.clipboard.writeText(resultURL).then(() => {
                alert('Much copied! Very success. Wow! 🐕');
            }).catch(() => {
                alert('Error copying. Such sad. Wow.');
            });
        }
        
        document.getElementById('urlInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                unblockURL();
            }
        });
        
        // Check if URL parameter exists and decode it
        const params = new URLSearchParams(window.location.search);
        const encodedURL = params.get('url');
        if (encodedURL) {
            try {
                const decodedURL = atob(encodedURL);
                window.location.href = decodedURL;
            } catch (e) {
                console.log('Invalid encoded URL');
            }
        }
    </script>
</body>
</html>
