<body>

<h1>💰 Ultimate Clicker V2</h1>

<div class="stats">
  <h2>Coins: <span id="score">0</span></h2>
  <h3>💎 Gems: <span id="gems">0</span></h3>
  <h3>⭐ Level: <span id="level">1</span></h3>
</div>

<button id="clickBtn">CLICK</button>

<div class="shop">
  <h2>🏪 Shop</h2>

  <div class="upgrade">
    <p>⬆️ Click Power (+1)</p>
    <p>Cost: <span id="powerCost">10</span></p>
    <button onclick="buyPower()">Buy</button>
  </div>

  <div class="upgrade">
    <p>🤖 Auto Clicker (+1/sec)</p>
    <p>Cost: <span id="autoCost">50</span></p>
    <button onclick="buyAuto()">Buy</button>
  </div>

  <div class="upgrade">
    <p>🏭 Factory (+10/sec)</p>
    <p>Cost: <span id="factoryCost">500</span></p>
    <button onclick="buyFactory()">Buy</button>
  </div>

  <div class="upgrade">
    <p>🐱 Pet Helper (+2 click power)</p>
    <p>Cost: <span id="petCost">200</span></p>
    <button onclick="buyPet()">Buy</button>
  </div>

  <div class="upgrade">
    <button onclick="prestige()">⭐ Prestige</button>
  </div>
</div>

<div id="achievements">
<h2>🏆 Achievements</h2>
<p id="ach1">❌ 100 Coins</p>
<p id="ach2">❌ 1000 Coins</p>
<p id="ach3">❌ 10 Gems</p>
</div>

<audio id="clickSound" src="assets/click.mp3"></audio>

<script src="script.js"></script>
</body>
