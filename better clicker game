  border-radius:10px;
}
.stats h2,h3{margin:5px;}
#achievements{margin-top:30px;}
.coin{
  position:absolute;
  color:gold;
  font-weight:bold;
  animation:float 1s ease-out forwards;
}
@keyframes float{
  0%{opacity:1;transform:translateY(0);}
  100%{opacity:0;transform:translateY(-60px);}
}let score = 0, gems = 0, level = 1;
let clickPower = 1, autoClick = 0, factories = 0, pets = 0;
let powerCost = 10, autoCost = 50, factoryCost = 500, petCost = 200;

const scoreText = document.getElementById("score");
const gemsText = document.getElementById("gems");
const levelText = document.getElementById("level");
const clickSound = document.getElementById("clickSound");

function update(){
  scoreText.innerText = Math.floor(score);
  gemsText.innerText = gems;
  levelText.innerText = Math.floor(score/500)+1;

  document.getElementById("powerCost").innerText = powerCost;
  document.getElementById("autoCost").innerText = autoCost;
  document.getElementById("factoryCost").innerText = factoryCost;
  document.getElementById("petCost").innerText = petCost;

  checkAchievements();
}

document.getElementById("clickBtn").onclick = function(e){
  score += clickPower;
  if(Math.random()<0.05){gems++;}
  clickSound.play();
  spawnCoin(e);
  update();
  save();
}

function spawnCoin(e){
  let coin = document.createElement("div");
  coin.className="coin";
  coin.innerText="+"+clickPower;
  coin.style.left=(window.innerWidth/2)+"px";
  coin.style.top=(window.innerHeight/2)+"px";
  document.body.appendChild(coin);
  setTimeout(()=>coin.remove(),1000);
}

// Shop functions
function buyPower(){if(score>=powerCost){score-=powerCost;clickPower++;powerCost=Math.floor(powerCost*1.6);update();save();}}
function buyAuto(){if(score>=autoCost){score-=autoCost;autoClick++;autoCost=Math.floor(autoCost*2);update();save();}}
function buyFactory(){if(score>=factoryCost){score-=factoryCost;factories++;factoryCost=Math.floor(factoryCost*2.5);update();save();}}
function buyPet(){if(score>=petCost){score-=petCost;pets++;clickPower+=2;petCost=Math.floor(petCost*2);update();save();}}

// Prestige
function prestige(){if(score>=10000){let bonus=Math.floor(score/10000);gems+=bonus;score=0;clickPower=1;autoClick=0;factories=0;pets=0;alert("⭐ Prestige! You gained "+bonus+" gems");update();save();}}

