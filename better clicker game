<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ultimate Clicker V3</title>
<style>
body{
  font-family: Arial, sans-serif;
  margin:0;
  padding:0;
  overflow-x:hidden;
  background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=MnwxMTc3M3wwfDF8c2VhcmNofDF8fGdhbGF4eXxlbnwwfHx8fDE2MzkzNzU1NDA&ixlib=rb-4.0.3&q=80&w=1080') no-repeat center center fixed;
  background-size: cover;
  color:white;
  text-align:center;
}

h1{margin-top:20px;}
button{
  padding:20px 40px;
  font-size:24px;
  border:none;
  border-radius:12px;
  background:#22c55e;
  color:white;
  cursor:pointer;
  margin-top:10px;
}

button:hover{background:#16a34a;}
.shop{
  margin-top:30px;
}
.upgrade{
  background:rgba(30,41,59,0.8);
  padding:15px;
  margin:10px auto;
  width:260px;
  border-radius:10px;
}
.stats h2,h3{margin:5px;}
#achievements{margin-top:30px;}
.coin{
  position:absolute;
  color:gold;
  font-weight:bold;
  animation:float 1s ease-out forwards;
}
#lego{
  width:100px;
  margin:30px auto;
  cursor:pointer;
  transition: transform 0.2s;
}
#lego:active{transform: scale(0.9);}
@keyframes float{
  0%{opacity:1;transform:translateY(0);}
  100%{opacity:0;transform:translateY(-60px);}
}
</style>
</head>

<body>
<h1>💰 Ultimate Clicker V3</h1>
<div class="stats">
  <h2>Coins: <span id="score">0</span></h2>
  <h3>💎 Gems: <span id="gems">0</span></h3>
  <h3>⭐ Level: <span id="level">1</span></h3>
</div>

<button id="clickBtn">CLICK</button>

<img id="lego" src="https://upload.wikimedia.org/wikipedia/commons/7/7e/LEGO_logo.svg" alt="Lego">

<div class="shop">
<h2>🏪 Shop</h2>

<div class="upgrade">
<p>⬆️ Click Power (+1)</p>
<p>Cost: <span id="powerCost">10</span></p>
<button onclick="buyPower()">Buy</button>
</div>

<div class="upgrade">
<p>🤖 Auto Clicker (+1/sec)</p>
<p>Cost: <span id="autoCost">50</span></p>
<button onclick="buyAuto()">Buy</button>
</div>

<div class="upgrade">
<p>🏭 Factory (+10/sec)</p>
<p>Cost: <span id="factoryCost">500</span></p>
<button onclick="buyFactory()">Buy</button>
</div>

<div class="upgrade">
<p>🐱 Pet Helper (+2 click power)</p>
<p>Cost: <span id="petCost">200</span></p>
<button onclick="buyPet()">Buy</button>
</div>

<div class="upgrade">
<button onclick="prestige()">⭐ Prestige</button>
</div>
</div>

<div id="achievements">
<h2>🏆 Achievements</h2>
<p id="ach1">❌ 100 Coins</p>
<p id="ach2">❌ 1000 Coins</p>
<p id="ach3">❌ 10 Gems</p>
</div>

<audio id="clickSound" src="https://www.soundjay.com/buttons/sounds/button-16.mp3"></audio>

<script>
let score = 0, gems = 0, level = 1;
let clickPower = 1, autoClick = 0, factories = 0, pets = 0;
let powerCost = 10, autoCost = 50, factoryCost = 500, petCost = 200;

const scoreText = document.getElementById("score");
const gemsText = document.getElementById("gems");
const levelText = document.getElementById("level");
const clickSound = document.getElementById("clickSound");
const lego = document.getElementById("lego");

function update(){
  scoreText.innerText = Math.floor(score);
  gemsText.innerText = gems;
  levelText.innerText = Math.floor(score/500)+1;

  document.getElementById("powerCost").innerText = powerCost;
  document.getElementById("autoCost").innerText = autoCost;
  document.getElementById("factoryCost").innerText = factoryCost;
  document.getElementById("petCost").innerText = petCost;

  checkAchievements();
}

function spawnCoin(x=window.innerWidth/2, y=window.innerHeight/2){
  let coin = document.createElement("div");
  coin.className="coin";
  coin.innerText="+"+clickPower;
  coin.style.left=x+"px";
  coin.style.top=y+"px";
  document.body.appendChild(coin);
  setTimeout(()=>coin.remove(),1000);
}

document.getElementById("clickBtn").onclick = function(e){
  score += clickPower;
  if(Math.random()<0.05){gems++;}
  clickSound.play();
  spawnCoin();
  update();
  save();
}

// Lego touch bonus
lego.onclick = function(e){
  score += clickPower * 5;
  spawnCoin(e.clientX, e.clientY);
  update();
  save();
}

// Shop functions
function buyPower(){if(score>=powerCost){score-=powerCost;clickPower++;powerCost=Math.floor(powerCost*1.6);update();save();}}
function buyAuto(){if(score>=autoCost){score-=autoCost;autoClick++;autoCost=Math.floor(autoCost*2);update();save();}}
function buyFactory(){if(score>=factoryCost){score-=factoryCost;factories++;factoryCost=Math.floor(factoryCost*2.5);update();save();}}
function buyPet(){if(score>=petCost){score-=petCost;pets++;clickPower+=2;petCost=Math.floor(petCost*2);update();save();}}

// Prestige
function prestige(){if(score>=10000){let bonus=Math.floor(score/10000);gems+=bonus;score=0;clickPower=1;autoClick=0;factories=0;pets=0;alert("⭐ Prestige! You gained "+bonus+" gems");update();save();}}

// Achievements
function checkAchievements(){
  if(score>=100){document.getElementById("ach1").innerText="✅ 100 Coins";}
  if(score>=1000){document.getElementById("ach2").innerText="✅ 1000 Coins";}
  if(gems>=10){document.getElementById("ach3").innerText="✅ 10 Gems";}
}

// Auto-clickers and factories
setInterval(()=>{score+=autoClick;score+=factories*10;update();save();},1000);

// Save/load
function save(){
  localStorage.setItem("score",score);
  localStorage.setItem("gems",gems);
  localStorage.setItem("clickPower",clickPower);
  localStorage.setItem("autoClick",autoClick);
  localStorage.setItem("factories",factories);
  localStorage.setItem("pets",pets);
  localStorage.setItem("powerCost",powerCost);
  localStorage.setItem("autoCost",autoCost);
  localStorage.setItem("factoryCost",factoryCost);
  localStorage.setItem("petCost",petCost);
}
function load(){
  score=Number(localStorage.getItem("score"))||0;
  gems=Number(localStorage.getItem("gems"))||0;
  clickPower=Number(localStorage.getItem("clickPower"))||1;
  autoClick=Number(localStorage.getItem("autoClick"))||0;
  factories=Number(localStorage.getItem("factories"))||0;
  pets=Number(localStorage.getItem("pets"))||0;
  powerCost=Number(localStorage.getItem("powerCost"))||10;
  autoCost=Number(localStorage.getItem("autoCost"))||50;
  factoryCost=Number(localStorage.getItem("factoryCost"))||500;
  petCost=Number(localStorage.getItem("petCost"))||200;
  update();
}
load();
</script>
</body>
</html>
